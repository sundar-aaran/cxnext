{
  "name": "@cxnext/db",
  "version": "1.0.50",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:migrate": "tsc -p tsconfig.json && node dist/cli.js migrate",
    "db:prepare": "tsc -p tsconfig.json && node dist/cli.js prepare",
    "db:fresh": "tsc -p tsconfig.json && node dist/cli.js fresh --yes",
    "db:refresh": "tsc -p tsconfig.json && node dist/cli.js refresh --yes",
    "db:seed": "tsc -p tsconfig.json && node dist/cli.js seed",
    "db:status": "tsc -p tsconfig.json && node dist/cli.js status",
    "lint": "eslint . --config ../../eslint.config.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "kysely": "0.28.16",
    "mysql2": "^3.22.3",
    "zod": "^4.3.6"
  }
}
