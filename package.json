{
  "name": "cxnext",
  "version": "1.0.6",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo dev",
    "build": "corepack pnpm -r --no-bail build",
    "lint": "corepack pnpm -r --no-bail lint",
    "typecheck": "corepack pnpm -r --no-bail typecheck",
    "test": "vitest run",
    "github": "node apps/cli/src/github-helper.mjs",
    "github:now": "node apps/cli/src/github-now.mjs",
    "version:sync": "node scripts/version-sync.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css}\""
  },
  "devDependencies": {
    "@cxnext/config": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
